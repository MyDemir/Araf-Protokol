# ─── Araf Protocol Smart Contract Environment Variables ─────────────────
# KULLANIM: Bu dosyanın bir kopyasını oluşturup adını ".env" yapın.
# UYARI: .env dosyasını ASLA GitHub'a yüklemeyin (.gitignore içinde olmalı).

# ─── 1. Cüzdan ve Yetki Ayarları (ZORUNLU) ──────────────────────────────
# Deploy işlemini yapacak ve gas ücretini ödeyecek geliştirici cüzdanı
# DİKKAT: Başına 0x koyarak MetaMask Private Key (Gizli Anahtar) girilmelidir.
DEPLOYER_PRIVATE_KEY="0x_BURAYA_METAMASK_GIZLI_ANAHTARINIZI_YAPISTIRIN"

# Güvenlik Kuralı: Deploy sonrası kontratın sahipliğinin devredileceği adres.
# Komisyonların toplanacağı ve yetkilerin tutulacağı hazine cüzdanı (Public Adres).
TREASURY_ADDRESS="0x_BURAYA_HAZINE_CUZDAN_ADRESINI_YAPISTIRIN"

# ─── 2. RPC Bağlantıları (ZORUNLU / ÖNERİLEN) ───────────────────────────
# Base Sepolia Test Ağı RPC URL'si
# Daha stabil bir deploy için buraya Alchemy veya Infura HTTPS linkini girin.
# Örn: https://base-sepolia.g.alchemy.com/v2/YOUR_API_KEY
BASE_SEPOLIA_RPC_URL="https://sepolia.base.org"

# Base Mainnet (Gerçek Ağ) RPC URL'si
# Gerçek ağa çıkılacağı zaman güncellenmelidir.
BASE_RPC_URL="https://mainnet.base.org"

# ─── 3. Kontrat Doğrulama (OPSİYONEL) ───────────────────────────────────
# Ağa yüklenen (deploy edilen) kontratın kaynak kodlarını BaseScan'de doğrulamak (verify) ve herkesin okuyabilmesini sağlamak için gereklidir.
# https://basescan.org/myapikey adresinden ücretsiz alınabilir.
BASESCAN_API_KEY="BURAYA_BASESCAN_API_ANAHTARINI_YAPISTIRIN"

# ─── 4. Hardhat Gas Reporter (OPSİYONEL) ────────────────────────────────
# Yerel testleri çalıştırırken fonksiyonların ne kadar dolar ($) yaktığını görmek için bu ayarları aktifleştirebilirsiniz.
REPORT_GAS="true"

# Canlı ETH fiyatını çekmek için CoinMarketCap API anahtarı
CMC_API_KEY="BURAYA_COINMARKETCAP_API_ANAHTARINI_YAPISTIRIN"

# ─── Araf Protocol Contracts Environment Variables ────────────────────
# Copy this file to contracts/.env and replace placeholder values.
# Hardhat loads this file through dotenv from contracts/hardhat.config.js.

# ─── Network / signer ─────────────────────────────────────────────────
# Base Sepolia chainId: 84532
# Base Mainnet chainId: 8453
NETWORK=base-sepolia
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
DEPLOYER_PRIVATE_KEY=
BASESCAN_API_KEY=
REPORT_GAS=false
# CMC_API_KEY=

# ─── Public deploy guard ───────────────────────────────────────────────
# Required for public-chain escrow deploys: base-sepolia and base.
CONFIRM_PUBLIC_DEPLOY=no

# ─── Escrow deploy/configuration ───────────────────────────────────────
# contracts/scripts/deploy.js requires TREASURY_ADDRESS for all deploys.
# Public/custom deploys also require FINAL_OWNER_ADDRESS and it must differ from TREASURY_ADDRESS.
TREASURY_ADDRESS=0x0000000000000000000000000000000000000000
FINAL_OWNER_ADDRESS=0x0000000000000000000000000000000000000000

# Base Sepolia escrow deploy token config. Required when deploying to base-sepolia.
# deploy.js rejects MAINNET_* aliases on Base Sepolia; use these names exactly.
BASE_SEPOLIA_USDT_ADDRESS=0x0000000000000000000000000000000000000000
BASE_SEPOLIA_USDC_ADDRESS=0x0000000000000000000000000000000000000000

# Base Mainnet escrow deploy token config. Required when deploying to base.
BASE_MAINNET_USDT_ADDRESS=0x0000000000000000000000000000000000000000
BASE_MAINNET_USDC_ADDRESS=0x0000000000000000000000000000000000000000

# Local/custom only: use external token addresses instead of deploying MockERC20.
USE_EXTERNAL_TOKEN_ADDRESSES=false
EXTERNAL_USDT_ADDRESS=0x0000000000000000000000000000000000000000
EXTERNAL_USDC_ADDRESS=0x0000000000000000000000000000000000000000

# ─── Existing escrow / rewards deployment ─────────────────────────────
# Required by deployRewards.js on public networks; optional on local.
ARAF_ESCROW_ADDRESS=0x0000000000000000000000000000000000000000
FINAL_TREASURY_ADDRESS=0x0000000000000000000000000000000000000000
CONFIRM_FRESH_ESCROW_DEPLOY=no
CONFIRM_OVERWRITE_REWARDS_MANIFEST=no

# ─── Rewards configuration / smoke / treasury ops ─────────────────────
ARAF_REVENUE_VAULT_ADDRESS=0x0000000000000000000000000000000000000000
ARAF_REWARDS_ADDRESS=0x0000000000000000000000000000000000000000
REWARD_BPS=4000
CONFIRM_CONFIGURE_REWARDS=false
CONFIRM_TREASURY_SWITCH=false
CONFIRM_PUBLIC_SMOKE=no
EXPECTED_CURRENT_TREASURY_ADDRESS=0x0000000000000000000000000000000000000000

# Legacy/ops aliases only. Prefer the canonical names above.
# RPC_URL=<alias of BASE_SEPOLIA_RPC_URL or BASE_RPC_URL>
# PRIVATE_KEY=<alias of DEPLOYER_PRIVATE_KEY>
# REWARDS_VAULT_ADDRESS=<alias of ARAF_REVENUE_VAULT_ADDRESS>
# REWARDS_ADDRESS=<alias of ARAF_REWARDS_ADDRESS>

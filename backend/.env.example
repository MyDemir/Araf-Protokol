# ─── Server ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── MongoDB ─────────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/araf_protocol

# ─── Redis ───────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_MIN_64_CHARS
JWT_EXPIRES_IN=15m
# Trade-scoped PII tokens expire faster
PII_TOKEN_EXPIRES_IN=15m

# ─── Encryption (KMS / Envelope) ─────────────────────────
# In production: use AWS KMS / HashiCorp Vault
# For demo: store master key here (NEVER commit real values!)
MASTER_ENCRYPTION_KEY=CHANGE_THIS_32_BYTE_HEX_KEY_FOR_AES256

# ─── Base Network ────────────────────────────────────────
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
ARAF_ESCROW_ADDRESS=0x0000000000000000000000000000000000000000
CHAIN_ID=8453

# ─── Protocol ────────────────────────────────────────────
TREASURY_ADDRESS=0x0000000000000000000000000000000000000000
# Backend never holds private keys — relayer only!
# BACKEND_PRIVATE_KEY is intentionally absent

# ─── CORS ────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,https://araf.protocol

# ─── Server ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── MongoDB ─────────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/araf_protocol

# ─── Redis ───────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ─── JWT ─────────────────────────────────────────────────
# Minimum 64 karakter (512-bit) zorunlu!
# Üretmek için: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ASLA placeholder kullanmayın — uygulama başlarken entropy kontrolü yapılır.
JWT_SECRET=BURAYA_CRYPTO_RANDOM_BYTES_64_ILE_URETILMIS_HEX_YAPISTIRINIZ
JWT_EXPIRES_IN=15m
# Trade-scoped PII tokens expire faster
PII_TOKEN_EXPIRES_IN=15m

# ─── Encryption (KMS / Envelope) ─────────────────────────
# Production'da KMS_PROVIDER='env' kullanılamaz!
#
# Development (yerel test):
#   KMS_PROVIDER=env
#   MASTER_ENCRYPTION_KEY=<64 hex karakter>
#   Üretmek için: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Production (AWS KMS — önerilen):
#   KMS_PROVIDER=aws
#   AWS_KMS_KEY_ARN=arn:aws:kms:eu-west-1:123456789:key/xxx-xxx-xxx
#   AWS_ENCRYPTED_DATA_KEY=<base64-encoded CiphertextBlob>
#   AWS_REGION=eu-west-1
#
# Production (HashiCorp Vault — alternatif):
#   KMS_PROVIDER=vault
#   VAULT_ADDR=https://vault.araf.xyz:8200
#   VAULT_TOKEN=<vault-token>
#   VAULT_KEY_NAME=araf-master-key

KMS_PROVIDER=env
MASTER_ENCRYPTION_KEY=BURAYA_CRYPTO_RANDOM_BYTES_32_ILE_URETILMIS_HEX_YAPISTIRINIZ

# ─── Base Network ────────────────────────────────────────
# [ZORUNLU] Public fallback yoktur; explicit provider URL girilmelidir.
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY
# [KRİTİK] Backend provider fail-closed chain doğrulaması.
# RPC'nin yanlış ağa bağlanmasını engeller (worker/config/cancel verify).
EXPECTED_CHAIN_ID=8453
# Kanonik token env'leri (chain-aware)
# Base Mainnet (chainId=8453)
BASE_MAINNET_USDT_ADDRESS=0x0000000000000000000000000000000000000000
BASE_MAINNET_USDC_ADDRESS=0x0000000000000000000000000000000000000000
# Base Sepolia (chainId=84532)
BASE_SEPOLIA_USDT_ADDRESS=0x0000000000000000000000000000000000000000
BASE_SEPOLIA_USDC_ADDRESS=0x0000000000000000000000000000000000000000
# İzlenecek token seti (opsiyonel). Boşsa active chain'e göre BASE_MAINNET/BASE_SEPOLIA çiftinden türetilir.
ARAF_TRACKED_TOKENS=0x0000000000000000000000000000000000000000,0x0000000000000000000000000000000000000000
# Legacy alias (geriye uyum): MAINNET_USDT_ADDRESS / MAINNET_USDC_ADDRESS yalnız Base Mainnet için kabul edilir.

# WebSocket RPC — gerçek zamanlı event dinleme için önerilir
# Alchemy: wss://base-mainnet.g.alchemy.com/v2/YOUR_KEY
# Infura:  wss://base-mainnet.infura.io/ws/v3/YOUR_KEY
# Tanımsızsa HTTP RPC kullanılır (geriye uyumlu).
# BASE_WS_RPC_URL=wss://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Worker finality penceresi (safe checkpoint için block derinliği)
# Production default: 6 | Development default: 1
# WORKER_FINALITY_DEPTH=6

ARAF_ESCROW_ADDRESS=0x0000000000000000000000000000000000000000
# Legacy CHAIN_ID yalnız referans içindir; backend guard EXPECTED_CHAIN_ID kullanır.
CHAIN_ID=8453

# ─── Protocol ────────────────────────────────────────────
# Treasury adresi Gnosis Safe (multisig) olmalı!
# Tek EOA adresi kullanılırsa private key sızması durumunda
# pause/unpause ve treasury fonları riske girer.
# Minimum 3/5 multisig önerilir.
TREASURY_ADDRESS=0x0000000000000000000000000000000000000000
# Public/custom deploy için zorunlu final owner (treasury'den farklı olmalı)
FINAL_OWNER_ADDRESS=0x0000000000000000000000000000000000000000
# Backend never holds private keys — relayer only!
# BACKEND_PRIVATE_KEY is intentionally absent

# ─── Relayer (Reputation Decay Job) ─────────────────────
# D-04: reputationDecay.js'in on-chain decayReputation() çağırması için gerekli.
# Bu cüzdan SADECE decayReputation() fonksiyonunu çağırabilir.
# Fon hareketi yapamaz — ABI ile kısıtlı (minimal ABI pattern).
# Mainnet'te Gelato/Chainlink Automation ile değiştirilecek (zero-key hedef).
# Testnet için ayrı, düşük bakiyeli bir cüzdan kullanın.
# Üretmek için: node -e "const {ethers}=require('ethers'); console.log(ethers.Wallet.createRandom().privateKey)"
RELAYER_PRIVATE_KEY=0x_BURAYA_AYRI_BIR_CUZDAN_ANAHTARI_EKLE

# ─── SIWE ────────────────────────────────────────────────────────────────────
# Production'da mutlaka set edilmeli!
# Boş veya localhost bırakılırsa
# sunucu başlamaz (app.js'deki kontrol bunu engeller).
# Örn: araf.protocol veya app.araf.xyz (https:// olmadan, sadece domain)
SIWE_DOMAIN=localhost

# ─── CORS ────────────────────────────────────────────────
# Sadece gerçek production domain'leri yazın.
# Wildcard (*) production'da engellenir — sunucu başlamaz.
# Her origin http:// veya https:// ile başlamalı.
ALLOWED_ORIGINS=http://localhost:5173

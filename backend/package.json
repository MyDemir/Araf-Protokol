{
  "name": "araf-backend",
  "version": "2.0.0",
  "description": "Araf Protocol — Web2.5 Backend (Zero Private Key Relayer)",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev":    "nodemon scripts/app.js",
    "start":  "node scripts/app.js",
    "test":   "jest --forceExit",
    "lint":   "eslint scripts/",
    "migrate:identity:dry": "node scripts/migrations/normalizeIdentityFields.js --dry-run",
    "migrate:identity": "node scripts/migrations/normalizeIdentityFields.js"
  },
  "dependencies": {
    "express":           "^4.19.2",
    "mongoose":          "^8.4.0",
    "redis":             "^4.6.14",
    "siwe":              "^2.3.2",
    "ethers":            "^6.11.0",
    "jsonwebtoken":      "^9.0.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.3.1",
    "rate-limit-redis":  "^4.2.0",
    "helmet":            "^7.1.0",
    "cors":              "^2.8.5",
    "cookie-parser":     "^1.4.6",
    "dotenv":            "^16.4.5",
    "joi":               "^17.13.1",
    "winston":           "^3.13.0",
    "multer":            "^1.4.5-lts.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "jest":    "^29.7.0",
    "supertest":"^7.0.0"
  }
}

# ─── Araf Protocol Frontend Environment Variables ─────────────────────
# Copy this file to frontend/.env and replace placeholder values.
# Vite exposes only VITE_* variables to the browser bundle.

# ─── Backend API ───────────────────────────────────────────────────────
# Development empty fallback: http://localhost:4000/api
# Production empty fallback: /api same-origin rewrite/proxy
# Do not set an external absolute VITE_API_URL in production unless the code policy changes.
VITE_API_URL=http://localhost:4000

# ─── Dev UI Lab / Scenario Controller ─────────────────────────────────
# true enables the UI Lab scenario controller explicitly, including preview/production-mode builds.
# Leave false for public production deployments.
VITE_ENABLE_UI_LAB=false

# ─── Escrow + supported token addresses ───────────────────────────────
# Use values printed by contracts/scripts/deploy.js or contracts/deployments/<network>.json.
# Base Sepolia chainId: 84532
VITE_ESCROW_ADDRESS=0x0000000000000000000000000000000000000000
VITE_USDT_ADDRESS=0x0000000000000000000000000000000000000000
VITE_USDC_ADDRESS=0x0000000000000000000000000000000000000000

# ─── Rewards contracts (mirror/read-only integration) ─────────────────
# Use values printed by contracts/scripts/deployRewards.js or contracts/deployments/<network>-rewards.json.
VITE_REVENUE_VAULT_ADDRESS=0x0000000000000000000000000000000000000000
VITE_REWARDS_ADDRESS=0x0000000000000000000000000000000000000000
VITE_REWARDS_READ_ONLY=true

# Optional legacy/ops alias:
# VITE_REWARDS_VAULT_ADDRESS=<alias of VITE_REVENUE_VAULT_ADDRESS>
